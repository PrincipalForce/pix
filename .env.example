# Copy to .env.local and fill in any keys you want to pre-bake into the build.
# Per-user keys entered in AI Settings always override these.
#
# Anthropic (in-app agent)
VITE_ANTHROPIC_API_KEY=

# Google Gemini 2.5 Flash Image (Nano Banana)
VITE_GEMINI_API_KEY=

# OpenAI (gpt-image-1 / DALL-E 3)
VITE_OPENAI_API_KEY=

# Replicate (Flux, Real-ESRGAN, etc.)
VITE_REPLICATE_API_KEY=

# remove.bg
VITE_REMOVEBG_API_KEY=
